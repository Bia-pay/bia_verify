PORT=5001
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biaverify
REDIS_URL=redis://localhost:6379
JWT_SECRET=super-secret-business-jwt-key-987654321
JWT_ADMIN_SECRET=super-secret-admin-jwt-key-987654321
ENCRYPTION_KEY=12345678901234567890123456789012
PII_RETENTION_DAYS=90

# AWS S3 Storage configurations (Defaults to local filesystem storage if set to 'mock-aws-key')
AWS_ACCESS_KEY_ID=mock-aws-key
AWS_SECRET_ACCESS_KEY=mock-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=biaverify-kyc-docs

# Upstream provider configuration (Defaults to local self-contained mock gateway)
UPSTREAM_VERIFICATION_URL=http://localhost:5001/api/mock-upstream
UPSTREAM_VERIFICATION_KEY=mock-upstream-api-key

# PalmPay checkout payment gateway settings (Defaults to local sandbox screen redirect)
PALMPAY_MERCHANT_ID=mock-merchant-id
PALMPAY_SECRET_KEY=mock-palmpay-secret
PALMPAY_API_URL=http://localhost:5001/api/mock-palmpay
